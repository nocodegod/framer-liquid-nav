:80 {
	root * /srv

	# Shared headers across both endpoints (Cache-Control set per path to avoid
	# global/path-scope conflicts where the global value silently wins).
	header {
		Access-Control-Allow-Origin *
		Access-Control-Allow-Methods "GET, OPTIONS"
	}

	# Production URL — long edge cache, short browser cache.
	header /LiquidNav.js {
		Content-Type "application/javascript; charset=utf-8"
		Cache-Control "public, max-age=300, s-maxage=31536000, stale-while-revalidate=86400"
	}

	# Dev/iteration aliases (LiquidNav2.js .. LiquidNav19.js) — every fetch
	# hits the origin so Framer always pulls the freshest bundle, no proxy or
	# browser layer holds onto a stale copy. Same bundle bytes as production.
	@aliases path_regexp ^/LiquidNav[0-9]+\.js$
	header @aliases {
		Content-Type "application/javascript; charset=utf-8"
		Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
		Pragma "no-cache"
		Expires "0"
	}

	@options method OPTIONS
	respond @options 204

	file_server
}
