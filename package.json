{
  "name": "framer-liquid-nav",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/LiquidNav.jsx --bundle --format=iife --global-name=__LIQUID_NAV__ --outfile=dist/LiquidNav.js --alias:react/jsx-runtime=./src/shims/react-jsx-runtime.js --alias:react=./src/shims/react.js --alias:react-dom=./src/shims/react-dom.js --alias:framer=./src/shims/framer.js --jsx=automatic --loader:.jsx=jsx --minify",
    "dev": "esbuild src/LiquidNav.jsx --bundle --format=iife --global-name=__LIQUID_NAV__ --outfile=dist/LiquidNav.js --alias:react/jsx-runtime=./src/shims/react-jsx-runtime.js --alias:react=./src/shims/react.js --alias:react-dom=./src/shims/react-dom.js --alias:framer=./src/shims/framer.js --jsx=automatic --loader:.jsx=jsx --watch"
  },
  "devDependencies": {
    "esbuild": "^0.20.0"
  }
}
